# Replace with your domain. Caddy provisions TLS on first boot.
# For an IP-only droplet with no domain yet, use `:80` instead.
{$SITE_ADDRESS::80} {
	encode zstd gzip
	reverse_proxy web:3000

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}
