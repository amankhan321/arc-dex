# ---- keeper (required) ----
# The rate-updater key. On this deployment that's the deployer wallet.
# Testnet key. NEVER a mainnet key, NEVER committed, NEVER pasted in a chat.
PRIVATE_KEY=

RPC_URL=https://rpc.testnet.arc.network
RATE_PROVIDER=0x5BD82828Ffd74d7d9df5B0266d8F8Dc6f05f6d74
TWAP=0x1081ea6642F8f67dc1ff8A40b8A60900c0180dBE

# ---- web via caddy (optional) ----
# With a domain, set it and Caddy fetches TLS automatically. Without one,
# leave unset and the site serves plain HTTP on :80.
# SITE_ADDRESS=arcbook.yourdomain.com
